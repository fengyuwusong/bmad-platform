# Platform default LLM configuration
# These values are used when the user has not configured a custom LLM provider.
# NEXT_PUBLIC_ prefix makes them available in the browser bundle.

# API key for the default LLM provider (e.g. ZhipuAI GLM)
NEXT_PUBLIC_DEFAULT_API_KEY=your_api_key_here

# Default model name
NEXT_PUBLIC_DEFAULT_MODEL=glm-4-flash
